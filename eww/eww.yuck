(include "./widgets/music_displayer/music_window.yuck")

(defwindow media_window
    :monitor 1 
    :geometry (geometry :x "15px"
                        :y "55px"
                        :width "460px"
                        :height "230px"
                        :anchor "top right")
    :stacking "fg"
    :exclusive false
    (music-player-widget)
)

